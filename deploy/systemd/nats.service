[Unit]
Description=NATS Server for Lafufu
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=lafufu
Group=lafufu
ExecStart=/usr/local/bin/nats-server -c /etc/nats/nats-server.conf
Restart=on-failure
RestartSec=5s
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
